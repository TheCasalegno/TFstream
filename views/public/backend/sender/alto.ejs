<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Salto in Alto - Inserimento RealTime</title>
  </head>
  <body>
    <form action="/sender/alto" method="POST">
      <h1>Inserimento REAL-TIME - Salto in Alto</h1>
      <hr width="100%" />
      <br />
      <div style="text-align: center">
        <h2>Misura <i>(espressa in cm)</i></h2>
        <input
          style="
            font-size: 60px;
            text-align: center;
            width: 300px;
            height: 70px;
          "
          required="true"
          type="number"
          name="misura"
          value="<%= misura %>"
        />
        <h2>Pettorale</h2>
        <input
          style="
            font-size: 60px;
            text-align: center;
            width: 300px;
            height: 70px;
          "
          required="true"
          type="number"
          name="pettorale"
        />
        <br />
        <h2>Risultato</h2>
        <label
          style="
            padding-top: 5px;
            padding-bottom: 5px;
            padding-left: 10px;
            padding-right: 10px;
            border-style: solid;
            border-width: 1px;
            font-size: 40px;
            font-family: 'Ubuntu', sans-serif;
          "
          for="valido"
        >
          <input
            value="O"
            style="transform: scale(2)"
            type="radio"
            id="valido"
            name="risultato"
            required="true"
          />
          VALIDO (O)
        </label>
        <br />
        <label
          style="
            padding-top: 5px;
            padding-bottom: 5px;
            padding-left: 10px;
            padding-right: 10px;
            border-style: solid;
            border-width: 1px;
            font-size: 40px;
            font-family: 'Ubuntu', sans-serif;
          "
          for="nullo"
        >
          <input
            value="X"
            style="transform: scale(2)"
            type="radio"
            id="nullo"
            name="risultato"
            required="true"
          />
          NULLO (X)
        </label>
        <br>
        <button
          style="font-size: 30px; height: 80px; width: 200px"
          type="submit"
        >
          INVIA
        </button>
      </div>
      <br />
      <h1>Ultimo inserimento</h1>
      <hr />
      <h2>Pettorale: <%-pettorale %></h2>
      <h2>Nome: <%-nome %></h2>
      <h2>Misura: <%-misura %></h2>
      <h2>Società: <%-squadra %></h2>
    </form>

    <script>
      let error = "<%= errore %>";
      let pettorale = "<%= pettorale %>";
      if (error == "matching") {
        alert(
          "ATTENZIONE!\nNon è stato trovato nessun atleta con il pettorale " +
            pettorale
        );
      }
    </script>
  </body>
</html>
