<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Salto in Lungo - Inserimento RealTime</title>
  </head>
  <body>
    <form action="/sender/lungo" method="POST">
      <h1>Inserimento REAL-TIME - Salto in Lungo</h1>
      <hr width="100%" />
      <br />
      <div style="text-align: center">
        <h2>Misura <i>(espressa in cm)</i></h2>
        <input
          style="
            font-size: 60px;
            text-align: center;
            width: 300px;
            height: 70px;
          "
          required="true"
          type="number"
          name="misura"
        />
        <h2>Pettorale</h2>
        <input
          style="
            font-size: 60px;
            text-align: center;
            width: 300px;
            height: 70px;
          "
          required="true"
          type="number"
          name="pettorale"
        />
        <br />
        
        <button
          style="font-size: 30px; height: 80px; width: 200px"
          type="submit"
        >
          INVIA
        </button>
      </div>
      <br />
      <h1>Ultimo inserimento</h1>
      <hr />
      <h2>Pettorale: <%-pettorale %></h2>
      <h2>Nome: <%-nome %></h2>
      <h2>Misura: <%-risultato %></h2>
      <h2>Società: <%-squadra %></h2>
    </form>

    <script>
      let error = "<%= errore %>";
      let pettorale = "<%= pettorale %>";
      if (error == "matching") {
        alert(
          "ATTENZIONE!\nNon è stato trovato nessun atleta con il pettorale " +
            pettorale
        );
      }
    </script>
  </body>
</html>
